---
import Layout from '../layouts/Layout.astro';

interface GitHubLabel {
  name: string;
  color: string;
}

interface GitHubIssue {
  number: number;
  title: string;
  state: 'open' | 'closed';
  labels: GitHubLabel[];
  created_at: string;
  closed_at: string | null;
  html_url: string;
}

const headers: Record<string, string> = {};
if (import.meta.env.GITHUB_TOKEN) {
  headers['Authorization'] = `Bearer ${import.meta.env.GITHUB_TOKEN}`;
}

const res = await fetch(
  'https://api.github.com/repos/nhall/house/issues?state=all&per_page=100',
  { headers }
);
const issues: GitHubIssue[] = await res.json();

const open = issues.filter(i => i.state === 'open');
const closed = issues.filter(i => i.state === 'closed');
const total = issues.length;
const healthPct = total > 0 ? Math.round((closed.length / total) * 100) : 0;

const TYPE_LABELS = ['Plumbing', 'HVAC', 'Electrical', 'Cosmetic', 'Structural', 'Landscaping'];

function countByLabel(list: GitHubIssue[], labelName: string) {
  return list.filter(i => i.labels.some(l => l.name === labelName)).length;
}

const typeBreakdown = TYPE_LABELS
  .map(name => ({ name, count: countByLabel(issues, name) }))
  .filter(t => t.count > 0)
  .sort((a, b) => b.count - a.count);

const maxTypeCount = typeBreakdown[0]?.count ?? 1;

const recentFixes = [...closed]
  .sort((a, b) => new Date(b.closed_at!).getTime() - new Date(a.closed_at!).getTime())
  .slice(0, 6);

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric', month: 'short', day: 'numeric'
  });
}

function labelStyle(color: string) {
  const r = parseInt(color.slice(0, 2), 16);
  const g = parseInt(color.slice(2, 4), 16);
  const b = parseInt(color.slice(4, 6), 16);
  const luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
  const textColor = luminance > 0.55 ? '#1A1714' : '#ffffff';
  return `background:#${color};color:${textColor}`;
}

const NON_TYPE_LABELS = new Set(['Interior', 'Exterior', 'Professional', 'Basement', 'Kitchen', 'Bathroom', 'Bedroom', 'Utility Room', 'Landscaping']);
---

<Layout title="Dashboard" activePage="dashboard">
  <div class="page-header">
    <h1>Home Dashboard</h1>
    <p>Bug tracker for the house.</p>
  </div>

  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-value">{total}</div>
      <div class="stat-label">Issues filed</div>
    </div>
    <div class="stat-card">
      <div class="stat-value closed">{closed.length}</div>
      <div class="stat-label">Fixed</div>
    </div>
    <div class="stat-card">
      <div class="stat-value open">{open.length}</div>
      <div class="stat-label">Open</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">{healthPct}%</div>
      <div class="stat-label">Complete</div>
    </div>
  </div>

  {open.length > 0 && (
    <div class="section">
      <div class="section-title">Open</div>
      {open.map(issue => (
        <a href={issue.html_url} target="_blank" rel="noopener" class="issue-card is-open">
          <span class="issue-icon">
            <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7" stroke="#A8521A" stroke-width="1.5"/>
              <circle cx="8" cy="8" r="3" fill="#A8521A"/>
            </svg>
          </span>
          <span class="issue-body">
            <span class="issue-title">{issue.title}</span>
            <span class="issue-meta">
              <span class="issue-number">#{issue.number}</span>
              <span class="issue-date">Opened {formatDate(issue.created_at)}</span>
              {issue.labels.map(label => (
                <span class="label-chip" style={labelStyle(label.color)}>{label.name}</span>
              ))}
            </span>
          </span>
        </a>
      ))}
    </div>
  )}

  <div class="two-col">
    <div class="section">
      <div class="section-title">Recently fixed</div>
      {recentFixes.map(issue => (
        <a href={issue.html_url} target="_blank" rel="noopener" class="issue-card is-closed">
          <span class="issue-icon">
            <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7" stroke="#2F6644" stroke-width="1.5"/>
              <path d="M5 8l2 2 4-4" stroke="#2F6644" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <span class="issue-body">
            <span class="issue-title">{issue.title}</span>
            <span class="issue-meta">
              <span class="issue-number">#{issue.number}</span>
              <span class="issue-date">Fixed {formatDate(issue.closed_at!)}</span>
            </span>
          </span>
        </a>
      ))}
    </div>

    <div class="section">
      <div class="section-title">By type</div>
      <div class="breakdown-list">
        {typeBreakdown.map(({ name, count }) => (
          <div class="breakdown-row">
            <span class="breakdown-label">{name}</span>
            <div class="breakdown-bar-wrap">
              <div class="breakdown-bar-fill" style={`width:${Math.round((count / maxTypeCount) * 100)}%`}></div>
            </div>
            <span class="breakdown-count">{count}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>
